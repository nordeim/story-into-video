# ──────────────────────────────────────────────────────────────────────────
# StoryIntoVideo — Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it contains secrets.
#
# The Zod schema in src/lib/env/index.ts validates all of these at module load.
# The app fails fast (refuses to boot) if any required var is missing/invalid.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (Neon) ──
# Pooled connection for the app (uses Neon's -pooler host)
DATABASE_URL=postgresql://user:pass@ep-pooled.region.aws.neon.tech/db?sslmode=require
# Direct connection for migrations (uses Neon's direct host)
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-direct.region.aws.neon.tech/db?sslmode=require

# ── Auth (Auth.js v5) ──
# Generate with: openssl rand -base64 32  (must be ≥32 chars, no known-weak values)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ── Google OAuth (optional — both required to enable) ──
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Providers ──
OPENAI_API_KEY=sk-...
REPLICATE_API_TOKEN=r8_...
ELEVENLABS_API_KEY=

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Cloudflare R2 ──
# Create at: https://dash.cloudflare.com/ > R2 Object Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_UPLOADS=siv-uploads
R2_BUCKET_GENERATED=siv-generated
R2_BUCKET_VIDEOS=siv-videos

# ── Inngest (Job Orchestration) ──
# Create at: https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Email (Resend) ──
# Create at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Rate Limiting (Upstash Redis) ──
# Create at: https://console.upstash.com/ > Redis
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Monitoring (Sentry) ──
# Create at: https://sentry.io/
SENTRY_DSN=https://example@sentry.io/1

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
